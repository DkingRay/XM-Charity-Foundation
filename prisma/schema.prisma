generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
}

model Donation {
  id        String   @id @default(cuid())
  amount    Float
  currency  String   @default("USD")
  recurring Boolean  @default(false)
  name      String
  email     String
  phone     String   @default("")
  status    String   @default("pending")
  reference String   @unique
  createdAt DateTime @default(now())
}

model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String   @default("")
  message   String
  createdAt DateTime @default(now())
}

model Volunteer {
  id          String   @id @default(cuid())
  name        String
  email       String
  phone       String   @default("")
  interest    String   @default("")
  message     String   @default("")
  createdAt   DateTime @default(now())
}

model Partner {
  id          String   @id @default(cuid())
  name        String
  organization String  @default("")
  email       String
  phone       String   @default("")
  message     String   @default("")
  createdAt   DateTime @default(now())
}

model Program {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  image       String   @default("/images/placeholder.svg")
  summary     String
  description String
  metrics     Json     @default("[]")
  objectives  String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MediaItem {
  id        String   @id @default(cuid())
  image     String
  category  String
  type      String   @default("photo")
  title     String
  span      String?
  createdAt DateTime @default(now())
}

model Event {
  id          String   @id @default(cuid())
  title       String
  date        String
  isoDate     String
  location    String
  image       String   @default("/images/placeholder.svg")
  category    String   @default("Events")
  description String
  status      String   @default("upcoming")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
