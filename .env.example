# Supabase pooled connection (used at runtime by Prisma)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Supabase session-mode connection (used by Prisma for migrations)
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-[REGION].pooler.supabase.com:5432/postgres"

# Admin dashboard login
ADMIN_PASSWORD="change-me"

# JWT signing secret
JWT_SECRET="change-this-to-a-random-secret-in-production"
