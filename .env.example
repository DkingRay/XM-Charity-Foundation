# PostgreSQL connection string — get one from Neon (free) or Vercel Postgres
# Run: npx prisma migrate dev  (creates the tables)
# Then: node prisma/seed.js     (seeds admin account)
DATABASE_URL="postgresql://user:password@ep-example-123456.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Admin dashboard login — use the same value on Vercel
ADMIN_PASSWORD="admin123"

# JWT signing secret — generate a random string for production
JWT_SECRET="change-this-to-a-random-secret-in-production"
